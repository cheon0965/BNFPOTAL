{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_HOST;Port=YOUR_PORT;Database=BnfErpPortal;User Id=YOUR_USER;Password=YOUR_PASSWORD;SslMode=None;AllowPublicKeyRetrieval=True;CharSet=utf8mb4;"
  },
  "Jwt": {
    "Secret": "REPLACE_WITH_LONG_RANDOM_SECRET",
    "Issuer": "BnfErpPortal",
    "Audience": "BnfErpPortalUsers",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "FileStorage": {
    "UploadPath": "C:\\uploads",
    "MaxFileSizeMB": 10,
    "AllowedExtensions": [
      ".png",
      ".jpg",
      ".jpeg",
      ".gif",
      ".pdf",
      ".doc",
      ".docx",
      ".xls",
      ".xlsx",
      ".txt",
      ".zip"
    ]
  },
  "Email": {
    "Host": "smtp.example.com",
    "Port": 587,
    "User": "no-reply@example.com",
    "Password": "REPLACE_WITH_EMAIL_PASSWORD",
    "From": "no-reply@example.com",
    "EnableSsl": true
  },
  "App": {
    "Urls": "http://0.0.0.0:3000/"
  }
}
